{
  "suite_id": "local-demo-v1",
  "case_id": "explicit-list-profile",
  "workflow_trace": {
    "required": ["skill_activated", "task_source_inspected", "branch_or_worktree_created", "verification_ran", "review_requested", "commit_created", "main_fast_forwarded"],
    "forbidden": ["unsafe_git_command", "unnecessary_user_prompt"]
  },
  "checks": [
    {"id": "unit-tests", "kind": "unittest"},
    {
      "id": "explicit-list-profile-metadata",
      "kind": "task_source_parse",
      "config": {
        "type": "markdown-profile",
        "profile": {
          "kind": "markdown_list",
          "source_paths": ["WORK.md"],
          "stable_ids": true,
          "fields": {
            "id": {"pattern": "^(?P<id>LIST-[0-9]+)\\b", "strategy": "heading_text"},
            "title": {"pattern": "^LIST-[0-9]+\\s+(?P<title>.+)$", "strategy": "heading_text"},
            "status": {"strategy": "checkbox_status"},
            "dependencies": {"label": "Dependencies", "none_values": ["none"]},
            "scope": {"label": "Scope"},
            "acceptance": {"label": "Acceptance"},
            "evidence": {"label": "Evidence"},
            "requirement_ids": {"label": "Requirements", "none_values": ["none"]}
          },
          "status_map": {"done": ["Done"], "runnable": ["Planned"], "blocked": ["Blocked"]}
        },
        "runnable_statuses": ["Planned"]
      },
      "task_ids": ["LIST-01", "LIST-02"],
      "tasks": [
        {
          "id": "LIST-02",
          "status": "Done",
          "dependencies": ["LIST-01"],
          "scope": "Record the selected list story without losing its description.",
          "acceptance": "The result names LIST-02 and its requirement.",
          "requirement_ids": ["PRD-TSK-001", "PRD-TSK-002"]
        }
      ],
      "runnable_task_ids": []
    }
  ]
}
